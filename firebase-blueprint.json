{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's profile photo URL" },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "The user's role" }
      },
      "required": ["uid", "email"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking request from a client",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the booking" },
        "name": { "type": "string", "description": "The client's name" },
        "email": { "type": "string", "format": "email", "description": "The client's email" },
        "phone": { "type": "string", "description": "The client's phone number" },
        "service": { "type": "string", "description": "The service requested" },
        "date": { "type": "string", "format": "date", "description": "The requested date" },
        "message": { "type": "string", "description": "Additional message from the client" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"], "description": "The status of the booking" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the booking was created" },
        "uid": { "type": "string", "description": "The UID of the user who made the booking (if logged in)" }
      },
      "required": ["name", "email", "service", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of booking requests"
    }
  }
}
